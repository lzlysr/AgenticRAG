# AgenticRAG project-local environment.
# Copy to .env and fill the cloud API key/model if you use Judge or synthesis.

# Local retrieval models
MODEL_HUB=/data/lzl/workspace/AgenticRAG/models
BGE_M3_PATH=/data/lzl/workspace/AgenticRAG/models/bge-m3
BGE_RERANKER_PATH=/data/lzl/workspace/AgenticRAG/models/bge-reranker-v2-m3

# Financial corpus / index
NEWS_CORPUS_DIR=/data/lzl/workspace/AgenticRAG/data/financial_eval
NEWS_INDEX_DIR=/data/lzl/workspace/AgenticRAG/data/financial_all/indexes

# Agent inference LLM: local vLLM serving models/Qwen3-4B
VLLM_BASE_URL=http://localhost:9097/v1
AGENT_LLM_MODEL=Qwen3-4B
PROMPT_LANG=zh

# Optional local 32B service if you run it
VLLM_32B_URL=http://localhost:9094/v1

# DeepSeek cloud model for Judge and data synthesis.
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key

JUDGE_LLM_MODEL=deepseek-v4-flash
SYNTH_LLM_MODEL=deepseek-v4-flash

# GRPO reward script reads these direct Judge variables.
# Keep them aligned with the DeepSeek model above if training/reward_agentic_rag.py is used.
JUDGE_BASE_URL=https://api.deepseek.com
JUDGE_MODEL=deepseek-v4-flash
JUDGE_API_KEY=replace-with-your-deepseek-api-key
